{
  "name": "ai-office-addin",
  "version": "1.0.0",
  "description": "Multi-provider AI Office Add-in for Excel, Word, and PowerPoint",
  "scripts": {
    "start": "concurrently \"npm run server\" \"npm run dev\"",
    "dev": "webpack serve --mode development",
    "server": "node server/index.js",
    "build": "webpack --mode production",
    "install-certs": "office-addin-dev-certs install"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.30.0",
    "@microsoft/office-js": "^1.1.90",
    "cors": "^2.8.5",
    "express": "^4.21.0",
    "openai": "^4.68.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1"
  },
  "devDependencies": {
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/office-js": "^1.0.420",
    "@types/react": "^18.3.3",
    "@types/react-dom": "^18.3.0",
    "concurrently": "^9.0.0",
    "css-loader": "^7.1.2",
    "html-webpack-plugin": "^5.6.0",
    "office-addin-dev-certs": "^1.11.0",
    "style-loader": "^4.0.0",
    "ts-loader": "^9.5.1",
    "typescript": "^5.5.4",
    "webpack": "^5.94.0",
    "webpack-cli": "^5.1.4",
    "webpack-dev-server": "^5.0.4"
  }
}
